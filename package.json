{
  "name": "blazed-past-us",
  "version": "0.8.9",
  "description": "A static blog framework made for developers that allows content to be written in Markdown directly from the IDE.",
  "license": "MIT",
  "author": "gass-git",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/gass-git/blazed-past-us"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "blazed-past-us": "dist/cli/install-scaffold.js",
    "blazed": "dist/cli/build.js"
  },
  "scripts": {
    "build": "rimraf dist && tsc && node copy-template.js",
    "dev": "rimraf --glob \"*.tgz\" && npm run build && npm pack && npm link"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "fs-extra": "^11.3.4",
    "prettier": "^3.6.2",
    "rimraf": "^6.1.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/mdast": "^4.0.4",
    "chalk": "^5.6.2",
    "rehype-pretty-code": "^0.14.1",
    "rehype-raw": "^7.0.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-inline-svg-flex": "^0.3.4",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.1.0"
  },
  "keywords": [
    "static-site",
    "blog",
    "markdown"
  ]
}
